# ============================================================
# Laravel — ignore per-project sensitive and generated files
# ============================================================
**/vendor/
**/.env
**/.env.backup
**/.env.production
**/node_modules/
**/storage/logs/*.log
**/storage/framework/cache/data/*
**/storage/framework/sessions/*
**/storage/framework/views/*
**/bootstrap/cache/*.php
**/public/hot
**/public/storage
**/.phpunit.result.cache
**/coverage/

# ============================================================
# Compiled assets (Vite / Mix)
# ============================================================
**/public/build/
**/public/css/app.css
**/public/js/app.js

# ============================================================
# OS generated files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE / Editor files
# ============================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================================
# SQLite (default Laravel dev DB — we use MySQL but just in case)
# ============================================================
**/database/*.sqlite
**/database/*.sqlite-journal

# ============================================================
# Composer lock is committed per-project (do NOT ignore it)
# composer.lock → keep it
# ============================================================
